// Toggl-like time tracker schema (ローカル SQLite / 単一ユーザー)
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// 常に1行。勤務設定の置き場。
model Settings {
  id                   String   @id @default(cuid())
  workStart            Int      @default(600)  // 定時開始 (分, 0-1440) 10:00
  workEnd              Int      @default(1110) // 定時終了 (分, 0-1440) 18:30
  workDays             String   @default("1,2,3,4,5") // 使う曜日 (0=Sun..6=Sat) CSV
  weeklyReportTemplate String   @default("## 今週の概要\n（2〜3文で要約）\n\n## 主な作業\n- プロジェクトごとに箇条書き\n\n## 課題・確認事項\n- なければ「特になし」")
  createdAt            DateTime @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  color     String
  archived  Boolean        @default(false)
  createdAt DateTime       @default(now())
  entries   TimeEntry[]
  tags      TagOnProject[]

  @@index([clientId])
}

model TimeEntry {
  id                  String       @id @default(cuid())
  projectId           String?
  project             Project?     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  start               DateTime
  end                 DateTime
  title               String?
  note                String?
  externalEventId     String?
  externalEventSource String?
  breakMinutes        Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  tags                TagOnEntry[]

  @@index([start])
  @@index([projectId])
  @@index([externalEventId])
}

model Tag {
  id        String         @id @default(cuid())
  name      String         @unique
  color     String         // hex #RRGGBB
  createdAt DateTime       @default(now())
  entries   TagOnEntry[]
  projects  TagOnProject[]
}

model TagOnEntry {
  id      String    @id @default(cuid())
  tagId   String
  tag     Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entryId String
  entry   TimeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([tagId, entryId])
  @@index([entryId])
  @@index([tagId])
}

model TagOnProject {
  id        String  @id @default(cuid())
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tagId, projectId])
  @@index([projectId])
  @@index([tagId])
}
