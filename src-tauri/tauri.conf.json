{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Track",
  "version": "0.2.0",
  "identifier": "dev.nemoto.track",
  "build": {
    "frontendDist": "http://127.0.0.1:8787",
    "devUrl": "http://127.0.0.1:8787",
    "beforeDevCommand": "npm run build && npm run local",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Track",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/track-server"
    ],
    "resources": {
      "../dist/client": "dist/client",
      "../database/migrations": "database/migrations"
    },
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
