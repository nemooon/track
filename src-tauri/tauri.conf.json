{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Track",
  "version": "0.2.1",
  "identifier": "com.nemooon.track",
  "build": {
    "frontendDist": "http://127.0.0.1:8787",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Track",
        "width": 1280,
        "height": 860,
        "minWidth": 375,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24.5
        },
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/track-server"
    ],
    "resources": {
      "../dist/client": "dist/client",
      "../database/migrations": "database/migrations",
      "binaries/TrackAIHelper.app": "TrackAIHelper.app"
    },
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "13.0"
    },
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
